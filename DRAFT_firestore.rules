rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net
    match /{document=**} {
      allow read, write: if false;
    }

    // Common Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.keys().hasAll(['name', 'email', 'avatar']) && 
             data.name is string && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.avatar is string && data.avatar.size() <= 500 &&
             (data.get('dailyAnalysesCount', 0) is number) &&
             (data.get('subscriptionStatus', 'none') in ['none', 'active', 'canceled']);
    }

    function isValidHistory(data) {
      return data.keys().hasAll(['title', 'content', 'createdAt']) &&
             data.title is string && data.title.size() <= 200 &&
             data.content is string && data.content.size() <= 50000 &&
             data.createdAt is timestamp;
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        // Action: Update Profile info
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'email', 'avatar', 'dailyAnalysesCount', 'lastAnalysisDate', 'subscriptionStatus', 'isPro'])
        // Note: In a production app, subscriptionStatus shouldn't be here, but for this demo simulation it is allowed.
      );

      // History Subcollection
      match /history/{historyId} {
        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidHistory(incoming()) && 
                       incoming().createdAt == request.time;
        allow update: if isOwner(userId) && isValidHistory(incoming()) && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['title']) &&
                       incoming().createdAt == existing().createdAt;
        allow delete: if isOwner(userId);
      }
    }
  }
}
